# ── Video Source ──────────────────────────────────────────────────────────────
# RTSP URL, file path, or webcam index (0)
VIDEO_SOURCE=0

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_NAME=yolov8n

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_ID=default

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Inference Worker ─────────────────────────────────────────────────────────
CONFIDENCE=0.25
TARGET_FPS=30
PUBLISH_FRAMES=true
LOG_LEVEL=INFO

# ── Gateway ──────────────────────────────────────────────────────────────────
# Comma-separated CORS origins (* = allow all for dev)
CORS_ORIGINS=*

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_GATEWAY_URL=http://localhost:8000
